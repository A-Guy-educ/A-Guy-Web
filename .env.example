# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name

# MongoDB Connection Pool Configuration (optional)
# Controls the maximum number of connections per Payload instance
# Default: 2 (production), 5 (tests)
# Increase only if load testing proves necessary (recommended max: 5)
# MONGODB_MAX_POOL_SIZE=2

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Cody dashboard public URL (for OG/Twitter meta tags)
CODY_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Config Manager Encryption Key (32+ characters required for AES-256-GCM)
CONFIG_MASTER_KEY=your-32-char-minimum-master-key-here

# Sentry configuration (error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Logging level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# LLM Provider Selection (default: gemini)
# Options: 'gemini', 'openai-compatible'
LLM_PROVIDER=gemini

# Google Gemini AI API Key (from Google AI Studio: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI-Compatible Provider Configuration
# Supports OpenAI API, Ollama, LM Studio, and any OpenAI-compatible API
# Priority: OPENAI_COMPATIBLE_* > OPENAI_*
OPENAI_COMPATIBLE_API_KEY=your-api-key-here
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1  # Optional: for custom endpoints (Ollama, LM Studio, etc.)
# Fallback to standard OpenAI (if OPENAI_COMPATIBLE_* not set)
OPENAI_API_KEY=your-openai-api-key-here

# Chat Context Feature Flags (default: false)
SUMMARY_MAINTENANCE_ENABLED=true
MEMORY_EXTRACTION_ENABLED=true
MEMORY_RETRIEVAL_ENABLED=true

# Tenant + MCP configuration
DEFAULT_TENANT_SLUG=default
MCP_ENABLED=false
MCP_API_KEY=your-mcp-api-key-here

BLOB_READ_WRITE_TOKEN="vercel_blob_XXXX"

# Analytics Configuration
# Presence of keys/tokens enables the platform automatically
# Debug mode is enabled in development, disabled in production

# Google Analytics 4 (set to enable GA4 tracking)
# ⚠️ IMPORTANT: Only ONE GA4 measurement ID should be active per environment
#
# Production GA4: G-M1QKYGXWVM (use for production environment only)
# Temporary/Pre-Launch GA4: G-49KEEFY1WE (use for staging/testing)
#
# Set NEXT_PUBLIC_GA4_MEASUREMENT_ID to one of the above based on your environment:
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-49KEEFY1WE

# Mixpanel (set to enable Mixpanel tracking)
# Project token: 4472fb6738b41a819dbbf76fad44108e
NEXT_PUBLIC_MIXPANEL_TOKEN=4472fb6738b41a819dbbf76fad44108e

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cody Operations Dashboard
GITHUB_TOKEN=your-github-token-with-repo-access
# Bot token for Cody actions (comments, PR reviews) - falls back to GITHUB_TOKEN if not set
CODY_BOT_TOKEN=your-bot-account-token
GITHUB_OWNER=your-github-org-or-username
GITHUB_REPO=your-github-repo-name
CODY_DASHBOARD_SECRET=your-dashboard-secret

# GitHub OAuth App — for Cody dashboard login (replaces "Who are you?" picker)
# Register at: https://github.com/settings/developers → New OAuth App
# Callback URL: https://your-domain/api/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-app-client-secret
# Git identity for Cody pipeline commits (used in CI)
GIT_USER_NAME=aguyaharonyair
GIT_USER_EMAIL=242132053+aguyaharonyair@users.noreply.github.com

# Remote Dev Environment (optional — enables remote Mac dev tools in Cody chat)
# Format: gh_username:secret_key:https://funnel-url
# Multiple users: comma-separated (e.g., alice:key1:https://alice.ts.net,bob:key2:https://bob.ts.net)
# When not set, the feature is completely invisible to users
# REMOTE_DEV_USERS=your_gh_username:your-secret-key:https://your-device.ts.net

# Vercel Deployment Protection Bypass (for embedding preview in iframe)
# Enable in Vercel: Project Settings → Deployment Protection → Protection Bypass for Automation
# The secret is automatically injected as VERCEL_AUTOMATION_BYPASS_SECRET in Vercel deployments
NEXT_PUBLIC_VERCEL_BYPASS_SECRET=your-vercel-bypass-secret

