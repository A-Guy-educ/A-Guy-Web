{
  "id": "chat-send-message-in-lesson",
  "name": "Student sends a message to AI tutor in lesson context",
  "journey": "student-chats-with-ai",
  "type": "feature",
  "area": "chat",
  "tags": ["chat", "ai", "lesson"],
  "locale": "he",
  "preconditions": [
    {
      "action": "seed",
      "entity": "course",
      "data": {
        "title": "Test English",
        "courseLabel": "אנ",
        "status": "published",
        "isActive": true,
        "accessType": "free"
      },
      "ref": "$course"
    },
    {
      "action": "seed",
      "entity": "chapter",
      "data": {
        "title": "Grammar",
        "course": "$course",
        "status": "published",
        "isActive": true
      },
      "ref": "$chapter"
    },
    {
      "action": "seed",
      "entity": "lesson",
      "data": {
        "title": "Verbs",
        "chapter": "$chapter",
        "type": "learning",
        "status": "published",
        "isActive": true
      },
      "ref": "$lesson"
    },
    {
      "action": "seed",
      "entity": "user",
      "data": { "role": "student" },
      "ref": "$student"
    }
  ],
  "steps": [
    {
      "action": "login",
      "input": { "userRef": "$student" }
    },
    {
      "action": "openLesson",
      "input": {
        "courseRef": "$course",
        "chapterRef": "$chapter",
        "lessonRef": "$lesson"
      }
    },
    {
      "action": "expectUrl",
      "input": { "pattern": "/lessons/" },
      "description": "Verify lesson page loads"
    }
  ],
  "teardown": "auto"
}
