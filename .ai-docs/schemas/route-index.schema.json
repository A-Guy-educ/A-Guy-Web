{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Route Index (Next.js App Router)",
  "type": "object",
  "required": ["routes", "metadata"],
  "properties": {
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["routePath", "filePath", "kind"],
        "properties": {
          "routePath": { "type": "string" },
          "filePath": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["page", "route", "layout", "loading", "error", "not-found"]
          },
          "segmentGroup": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": ["generatedAt", "totalRoutes"],
      "properties": {
        "generatedAt": { "type": "string" },
        "totalRoutes": { "type": "number" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
