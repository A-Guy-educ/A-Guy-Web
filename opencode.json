{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".ai-docs/BOOTSTRAP.md", ".ai-docs/quick-reference/CHEAT-SHEET.md"],
  "agent": {
    "build": {
      "model": "minimax/MiniMax-M2.1"
    },
    "plan": {
      "model": "anthropic/claude-opus-4-6"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated=true",
        "--no-usage-statistics"
      ]
    }
  }
}
