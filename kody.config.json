{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm typecheck",
    "lint": "pnpm lint",
    "lintFix": "pnpm lint:fix",
    "formatFix": "pnpm format",
    "testUnit": "pnpm test:unit"
  },
  "git": {
    "defaultBranch": "dev"
  },
  "github": {
    "owner": "A-Guy-educ",
    "repo": "A-Guy"
  },
  "paths": {
    "taskDir": ".kody/tasks"
  },
  "agent": {
    "provider": "minimax",
    "modelMap": {
      "cheap": "MiniMax-M2.7-highspeed",
      "mid": "MiniMax-M2.7-highspeed",
      "strong": "MiniMax-M2.7-highspeed"
    }
  },
  "release": {
    "releaseBranch": "main",
    "versionFiles": ["package.json"],
    "notifyCommand": "curl -s -X POST \"$SLACK_WEBHOOK_URL\" -H 'Content-Type: application/json' -d '{\"text\": \"\ud83d\ude80 a-guy v$VERSION released \u2014 https://github.com/A-Guy-educ/A-Guy/releases/tag/v$VERSION\"}'",
    "e2eCommand": "pnpm test:e2e"
  },
  "watch": {
    "enabled": true,
    "digestIssue": null,
    "model": "MiniMax-M2.7-highspeed",
    "provider": "minimax"
  },
  "stages": {
    "taskify": { "maxTurns": 300, "maxBudgetUsd": 15.0 },
    "plan": { "maxTurns": 300, "maxBudgetUsd": 10.0 },
    "build": { "maxTurns": 1000, "maxBudgetUsd": 50.0 },
    "verify": { "maxTurns": 200, "maxBudgetUsd": 5.0 },
    "review": { "maxTurns": 300, "maxBudgetUsd": 10.0 },
    "review-fix": { "maxTurns": 600, "maxBudgetUsd": 30.0 },
    "ship": { "maxTurns": 200, "maxBudgetUsd": 5.0 }
  },
  "timeouts": {
    "taskify": 6000,
    "plan": 6000,
    "build": 24000,
    "verify": 3000,
    "review": 6000,
    "review-fix": 12000,
    "ship": 2400
  },
  "devServer": {
    "command": "pnpm dev",
    "url": "http://localhost:3000",
    "readyPattern": "Ready in|compiled|started server|Local:|localhost:|\u2713 Ready",
    "readyTimeout": 180,
    "env": [
      "AI_BASE_URL",
      "AI_KEY",
      "AI_MODEL",
      "BLOB_READ_WRITE_TOKEN",
      "BRAIN_AUTH_KEY",
      "CRON_SECRET",
      "DATABASE_URL",
      "DATABASE_URL_ATLAS",
      "FIGMA_API_KEY",
      "GEMINI_API_KEY",
      "GROQ_API_KEY",
      "MINIMAX_API_KEY",
      "NEXT_PUBLIC_SERVER_URL",
      "OPENAI_API_KEY",
      "PAYLOAD_SECRET",
      "SLACK_WEBHOOK_URL",
      "SLACK_WEBHOOK_URL_DEV"
    ]
  }
}
