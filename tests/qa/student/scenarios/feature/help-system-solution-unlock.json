{
  "id": "help-system-solution-unlock",
  "name": "Student unlocks solution after using hint and guiding question",
  "journey": "student-solves-exercises",
  "type": "feature",
  "area": "exercises",
  "tags": ["help", "solution"],
  "locale": "he",
  "preconditions": [
    {
      "action": "seed",
      "entity": "course",
      "data": {
        "title": "Test Chemistry",
        "courseLabel": "כ",
        "status": "published",
        "isActive": true,
        "accessType": "free"
      },
      "ref": "$course"
    },
    {
      "action": "seed",
      "entity": "chapter",
      "data": {
        "title": "Elements",
        "course": "$course",
        "status": "published",
        "isActive": true
      },
      "ref": "$chapter"
    },
    {
      "action": "seed",
      "entity": "lesson",
      "data": {
        "title": "Periodic Table",
        "chapter": "$chapter",
        "type": "learning",
        "status": "published",
        "isActive": true
      },
      "ref": "$lesson"
    },
    {
      "action": "seed",
      "entity": "user",
      "data": { "role": "student" },
      "ref": "$student"
    }
  ],
  "steps": [
    {
      "action": "login",
      "input": { "userRef": "$student" }
    },
    {
      "action": "openLesson",
      "input": {
        "courseRef": "$course",
        "chapterRef": "$chapter",
        "lessonRef": "$lesson"
      }
    },
    {
      "action": "expectUrl",
      "input": { "pattern": "/lessons/" },
      "description": "Verify lesson page loads"
    }
  ],
  "teardown": "auto"
}
