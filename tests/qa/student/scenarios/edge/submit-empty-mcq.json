{
  "id": "submit-empty-mcq",
  "name": "Student tries to check answer without selecting an option",
  "journey": "student-solves-exercises",
  "type": "edge",
  "area": "exercises",
  "tags": ["edge", "validation"],
  "locale": "he",
  "preconditions": [
    {
      "action": "seed",
      "entity": "course",
      "data": {
        "title": "Test Empty",
        "courseLabel": "ר",
        "status": "published",
        "isActive": true,
        "accessType": "free"
      },
      "ref": "$course"
    },
    {
      "action": "seed",
      "entity": "chapter",
      "data": {
        "title": "Test Chapter",
        "course": "$course",
        "status": "published",
        "isActive": true
      },
      "ref": "$chapter"
    },
    {
      "action": "seed",
      "entity": "lesson",
      "data": {
        "title": "Test Lesson",
        "chapter": "$chapter",
        "type": "learning",
        "status": "published",
        "isActive": true
      },
      "ref": "$lesson"
    },
    {
      "action": "seed",
      "entity": "user",
      "data": { "role": "student" },
      "ref": "$student"
    }
  ],
  "steps": [
    {
      "action": "login",
      "input": { "userRef": "$student" }
    },
    {
      "action": "openLesson",
      "input": {
        "courseRef": "$course",
        "chapterRef": "$chapter",
        "lessonRef": "$lesson"
      }
    },
    {
      "action": "expectUrl",
      "input": { "pattern": "/lessons/" },
      "description": "Should load lesson page"
    }
  ],
  "teardown": "auto"
}
