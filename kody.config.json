{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm typecheck",
    "lint": "pnpm lint",
    "lintFix": "pnpm lint:fix",
    "formatFix": "pnpm format",
    "testUnit": "pnpm test:unit"
  },
  "git": {
    "defaultBranch": "dev"
  },
  "github": {
    "owner": "A-Guy-educ",
    "repo": "A-Guy"
  },
  "paths": {
    "taskDir": ".kody/tasks"
  },
  "agent": {
    "provider": "minimax",
    "modelMap": {
      "cheap": "MiniMax-M2.7-highspeed",
      "mid": "MiniMax-M2.7-highspeed",
      "strong": "MiniMax-M2.7-highspeed"
    }
  },
  "release": {
    "releaseBranch": "main",
    "versionFiles": ["package.json"],
    "notifyCommand": "curl -s -X POST \"$SLACK_WEBHOOK_URL\" -H 'Content-Type: application/json' -d '{\"text\": \"🚀 a-guy v$VERSION released — https://github.com/A-Guy-educ/A-Guy/releases/tag/v$VERSION\"}'"
  },
  "devServer": {
    "command": "pnpm dev",
    "url": "http://localhost:3000",
    "readyPattern": "Ready in|compiled|started server|Local:|localhost:|✓ Ready",
    "readyTimeout": 180,
    "env": [
      "AI_BASE_URL",
      "AI_KEY",
      "AI_MODEL",
      "BLOB_READ_WRITE_TOKEN",
      "BRAIN_AUTH_KEY",
      "CRON_SECRET",
      "DATABASE_URL",
      "DATABASE_URL_ATLAS",
      "FIGMA_API_KEY",
      "GEMINI_API_KEY",
      "GROQ_API_KEY",
      "MINIMAX_API_KEY",
      "NEXT_PUBLIC_SERVER_URL",
      "OPENAI_API_KEY",
      "PAYLOAD_SECRET",
      "SLACK_WEBHOOK_URL",
      "SLACK_WEBHOOK_URL_DEV"
    ]
  }
}
