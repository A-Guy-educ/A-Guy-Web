{
  "$schema": "https://raw.githubusercontent.com/aharonyaircohen/Kody-Engine-Lite/main/kody.config.schema.json",
  "quality": {
    "typecheck": "pnpm typecheck",
    "lint": "pnpm lint",
    "lintFix": "pnpm lint:fix",
    "formatFix": "pnpm format",
    "testUnit": "pnpm test:unit"
  },
  "git": {
    "defaultBranch": "kody"
  },
  "github": {
    "owner": "A-Guy-educ",
    "repo": "A-Guy"
  },
  "paths": {
    "taskDir": ".kody/tasks"
  },
  "agent": {
    "modelMap": {
      "cheap": "claude-haiku-4-5-20251001",
      "mid": "claude-sonnet-4-6",
      "strong": "claude-opus-4-6"
    },
    "stages": {
      "taskify": { "provider": "openai", "model": "gpt-5.3-codex" },
      "plan": { "provider": "claude", "model": "claude-opus-4-6" },
      "build": { "provider": "gemini", "model": "gemini-2.5-flash" },
      "review": { "provider": "claude", "model": "claude-sonnet-4-6" },
      "review-fix": { "provider": "gemini", "model": "gemini-2.5-flash" },
      "ship": { "provider": "gemini", "model": "gemini-2.5-flash" }
    }
  },
  "mcp": {
    "devServer": {
      "command": "pnpm dev",
      "url": "http://localhost:3000",
      "env": [
        "AI_BASE_URL",
        "AI_KEY",
        "AI_MODEL",
        "BLOB_READ_WRITE_TOKEN",
        "BRAIN_AUTH_KEY",
        "CRON_SECRET",
        "DATABASE_URL",
        "DATABASE_URL_ATLAS",
        "FIGMA_API_KEY",
        "GEMINI_API_KEY",
        "GROQ_API_KEY",
        "MINIMAX_API_KEY",
        "NEXT_PUBLIC_SERVER_URL",
        "OPENAI_API_KEY",
        "PAYLOAD_SECRET",
        "SLACK_WEBHOOK_URL",
        "SLACK_WEBHOOK_URL_DEV"
      ]
    }
  }
}
