# Test environment configuration
# This file is loaded by playwright.config.ts and overrides .env values

# DATABASE_URL=
# Leave empty for testcontainers (recommended for local dev)
# Testcontainers will auto-populate this at runtime
DEFAULT_TENANT_SLUG=default

# Suppress pino logger output during tests
LOG_LEVEL=silent

# Test encryption key for config-manager tests (not a real secret)
CONFIG_MASTER_KEY=test-config-master-key-for-ci-integration-tests-only

# BLOB_READ_WRITE_TOKEN — injected via CI secrets or local .env
# Leave unset to skip Vercel Blob integration tests locally

# Required by payload.config.ts — dummy value for unit tests
PAYLOAD_SECRET=test-payload-secret-for-unit-tests-only-not-real
