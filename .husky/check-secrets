#!/bin/sh
# Pre-commit hook to prevent committing secrets

# Check if .env file is staged
if git diff --cached --name-only | grep -q "^\.env$"; then
    echo "❌ ERROR: Attempting to commit .env file!"
    echo "The .env file should NEVER be committed to git."
    echo "Please unstage it with: git reset HEAD .env"
    exit 1
fi

# Check for potential API keys in staged files (excluding docs and example files)
if git diff --cached --name-only | grep -v -E '\.(md|example)$' | xargs git diff --cached -- | grep -q "AIzaSy[A-Za-z0-9_-]\{33\}"; then
    echo "⚠️  WARNING: Potential Google API key detected in staged code!"
    echo "Please make sure you're not committing sensitive keys."
    echo ""
    echo "If this is a false positive, you can skip this check with:"
    echo "git commit --no-verify"
    exit 1
fi

echo "✅ No secrets detected in staged files"
exit 0
