# .env.test.example - Test environment overrides
# Copy to .env.test and customize as needed
# Missing values automatically fall back to .env

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Leave empty for testcontainers (recommended for local dev)
# Testcontainers will auto-populate this at runtime
DATABASE_URL=

# Atlas test cluster for vector search tests
# Required when running: pnpm test:int:atlas or pnpm test:vector
# Get this from your Atlas project: mongodb+srv://user:pass@cluster.mongodb.net/test
DATABASE_URL_ATLAS=

# =============================================================================
# FEATURE FLAGS (enable all for comprehensive testing)
# =============================================================================
SUMMARY_MAINTENANCE_ENABLED=true
MEMORY_EXTRACTION_ENABLED=true
MEMORY_RETRIEVAL_ENABLED=true

# =============================================================================
# ALL OTHER VALUES FALL BACK TO .env
# No need to duplicate: PAYLOAD_SECRET, OPENAI_API_KEY, GEMINI_API_KEY, etc.
# =============================================================================
