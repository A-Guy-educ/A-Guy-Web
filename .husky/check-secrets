#!/bin/sh
# Pre-commit hook to prevent committing secrets

# Check if .env file is staged
if git diff --cached --name-only | grep -q "^\.env$"; then
    echo "❌ ERROR: Attempting to commit .env file!"
    echo "The .env file should NEVER be committed to git."
    echo "Please unstage it with: git reset HEAD .env"
    exit 1
fi

# Get staged files (excluding docs, examples, hooks, and lock files)
staged_files=$(git diff --cached --name-only | grep -v -E '\.(md|example|lock)$' | grep -v '^\.husky/')

if [ -z "$staged_files" ]; then
    echo "✅ No secrets detected in staged files"
    exit 0
fi

# Define secret patterns
check_pattern() {
    pattern=$1
    name=$2

    if echo "$staged_files" | xargs -I {} git diff --cached -- {} | grep -qE "$pattern"; then
        echo "⚠️  WARNING: Potential $name detected in staged code!"
        echo "Please make sure you're not committing sensitive keys."
        echo ""
        echo "To skip this check: git commit --no-verify"
        echo "Or use: SKIP_HOOKS=1 git commit -m \"message\""
        exit 1
    fi
}

# Check for various secret patterns relevant to this project
check_pattern "AIzaSy[A-Za-z0-9_-]{33}" "Google API key"
check_pattern "sk-[A-Za-z0-9]{32,}" "OpenAI API key"
check_pattern "ghp_[A-Za-z0-9]{36}" "GitHub Personal Access Token"
check_pattern "gho_[A-Za-z0-9]{36}" "GitHub OAuth Token"
check_pattern "mongodb(\+srv)?://[a-zA-Z0-9][^/\s]*" "MongoDB connection string"
check_pattern "AKIA[0-9A-Z]{16}" "AWS Access Key"
check_pattern "sk_live_[A-Za-z0-9]{24,}" "Stripe Live Key"
check_pattern "pk_live_[A-Za-z0-9]{24,}" "Stripe Publishable Key"
check_pattern "xox[baprs]-[0-9]{10,13}-[0-9]{10,13}-[a-zA-Z0-9]{24,}" "Slack Token"

echo "✅ No secrets detected in staged files"
exit 0
