{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_y1h4izkdxj1e_1","type":"tool_result","content":"1\t/**\n2\t * Integration test: lesson duplication orchestrator.\n3\t *\n4\t * Acceptance criteria:\n5\t *  1. Orchestrator runs at most 4 strategy calls in parallel\n6\t *  2. One exercise failing does not abort the run — remaining exercises complete\n7\t *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n8\t *  4. Final status is succeeded only when failures array is empty, else needs_review\n9\t *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n10\t */\n11\timport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\n12\timport { getPayload, type Payload } from 'payload'\n13\timport config from '@payload-config'\n14\t\n15\timport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\n16\timport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n17\t\n18\t<<<<<<< HEAD\n19\t// Mock the LLM variation service to inject failures deterministically.\n20\t// This bypasses the complex runStrategy mock and directly controls LLM call outcomes.\n21\tconst { mockState } = vi.hoisted(() => {\n22\t  let callCount = 0\n23\t  return {\n24\t    mockState: {\n25\t      reset() {\n26\t        callCount = 0\n27\t      },\n28\t      get next() {\n29\t        callCount++\n30\t        return callCount\n31\t      },\n32\t    },\n33\t  }\n34\t})\n35\t=======\n36\t// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n37\t// does not make real LLM calls in the integration test environment.\n38\t// The variation service is only called when level != 'none' &&\n39\t// (level != 'light' || scriptStrategy.needsAiFallback).\n40\t// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n41\t// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\n42\tlet _vgCallCount = 0\n43\tvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n44\t  generateVariation: vi\n45\t    .fn()\n46\t    .mockImplementation(\n47\t      async (\n48\t        input: { exercise: { id: string } },\n49\t        _payload: unknown,\n50\t      ): Promise<{ exercise: { id: string; content: { blocks: unknown[] } } }> => {\n51\t        _vgCallCount++\n52\t        // Force failure on the 3rd exercise (call count 3 = index 2)\n53\t        if (_vgCallCount === 3) {\n54\t          throw new Error('Forced failure for test')\n55\t        }\n56\t        return {\n57\t          exercise: {\n58\t            id: input.exercise.id,\n59\t            content: {\n60\t              blocks: [\n61\t                {\n62\t                  id: 'q-1',\n63\t                  type: 'question_select',\n64\t                  variant: 'mcq',\n65\t                  selectionMode: 'single',\n66\t                  prompt: {\n67\t                    type: 'rich_text',\n68\t                    format: 'md-math-v1',\n69\t                    value: 'What is 2+2?',\n70\t                    mediaIds: [],\n71\t                  },\n72\t                  answer: {\n73\t                    multiSelect: false,\n74\t                    options: [\n75\t                      {\n76\t                        id: 'a',\n77\t                        content: {\n78\t                          type: 'rich_text',\n79\t                          format: 'md-math-v1',\n80\t                          value: '3',\n81\t                          mediaIds: [],\n82\t                        },\n83\t                      },\n84\t                      {\n85\t                        id: 'b',\n86\t                        content: {\n87\t                          type: 'rich_text',\n88\t                          format: 'md-math-v1',\n89\t                          value: '4',\n90\t                          mediaIds: [],\n91\t                        },\n92\t                      },\n93\t                    ],\n94\t                    correctOptionIds: ['b'],\n95\t                  },\n96\t                  hint: {\n97\t                    type: 'rich_text',\n98\t                    format: 'md-math-v1',\n99\t                    value: 'Think arithmetic',\n100\t                    mediaIds: [],\n101\t                  },\n102\t                  solution: {\n103\t                    type: 'rich_text',\n104\t                    format: 'md-math-v1',\n105\t                    value: '2+2=4',\n106\t                    mediaIds: [],\n107\t                  },\n108\t                  fullSolution: {\n109\t                    type: 'rich_text',\n110\t                    format: 'md-math-v1',\n111\t                    value: 'Basic addition',\n112\t                    mediaIds: [],\n113\t                  },\n114\t                },\n115\t              ],\n116\t            },\n117\t          },\n118\t        }\n119\t      },\n120\t    ),\n121\t}))\n122\t>>>>>>> origin/dev\n123\t\n124\t// Mock the variation service — throws on the 3rd exercise call to simulate LLM failure\n125\tvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n126\t  generateVariation: vi.fn().mockImplementation(async () => {\n127\t    const n = mockState.next\n128\t    if (n === 3) {\n129\t      throw new Error('Forced LLM failure for test')\n130\t    }\n131\t    return {\n132\t      exercise: {\n133\t        id: `mock-exercise-${n}`,\n134\t        content: { blocks: [] },\n135\t      },\n136\t    }\n137\t  }),\n138\t}))\n139\t\n140\tasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n141\t  const slug = getDefaultTenantSlug()\n142\t  const existing = await payload.find({\n143\t    collection: 'tenants',\n144\t    where: { slug: { equals: slug } },\n145\t    limit: 1,\n146\t    overrideAccess: true,\n147\t  })\n148\t  if (existing.docs[0]) return existing.docs[0].id\n149\t  const created = await payload.create({\n150\t    collection: 'tenants',\n151\t    data: { name: slug, slug, status: 'active' },\n152\t    overrideAccess: true,\n153\t  })\n154\t  return created.id\n155\t}\n156\t\n157\t// Reset mock call count before each test to ensure the 3rd exercise always fails\n158\tbeforeEach(() => {\n159\t  mockState.reset()\n160\t})\n161\t\n162\tdescribe('Lesson duplication orchestrator — integration', () => {\n163\t  let payload: Payload\n164\t  let categoryId: string\n165\t  let courseId: string\n166\t  let chapterId: string\n167\t  let tenantId: string\n168\t  let sourceLessonId: string\n169\t  const cleanupLessonIds: string[] = []\n170\t  const cleanupExerciseIds: string[] = []\n171\t  const cleanupDuplicationIds: string[] = []\n172\t\n173\t  beforeEach(() => {\n174\t    _vgCallCount = 0\n175\t  })\n176\t\n177\t  beforeAll(async () => {\n178\t    payload = await getPayload({ config })\n179\t    tenantId = await ensureDefaultTenant(payload)\n180\t    const ts = Date.now()\n181\t\n182\t    const category = await payload.create({\n183\t      collection: 'categories',\n184\t      data: { title: `OrchCat ${ts}`, slug: `orch-cat-${ts}`, locale: 'he' },\n185\t    })\n186\t    categoryId = category.id\n187\t\n188\t    const course = await payload.create({\n189\t      collection: 'courses',\n190\t      data: {\n191\t        courseLabel: `ORCH-${ts}`,\n192\t        title: `Orch Course ${ts}`,\n193\t        locale: 'he',\n194\t        categories: [categoryId],\n195\t        order: 0,\n196\t        status: 'published',\n197\t        isActive: true,\n198\t        tenant: tenantId,\n199\t        pageAccessType: 'free',\n200\t        accessType: 'free',\n201\t        contentStatus: 'none',\n202\t        contentStatusVisible: true,\n203\t      },\n204\t      draft: false,\n205\t    })\n206\t    courseId = course.id\n207\t\n208\t    const chapter = await payload.create({\n209\t      collection: 'chapters',\n210\t      data: {\n211\t        title: `Orch Chapter ${ts}`,\n212\t        chapterLabel: `OCH-${ts}`,\n213\t        course: courseId,\n214\t        order: 0,\n215\t        status: 'published',\n216\t        isActive: true,\n217\t        tenant: tenantId,\n218\t        locale: 'he',\n219\t      },\n220\t    })\n221\t    chapterId = chapter.id\n222\t\n223\t    const lesson = await payload.create({\n224\t      collection: 'lessons',\n225\t      data: {\n226\t        title: `Orch Source Lesson ${ts}`,\n227\t        chapter: chapterId,\n228\t        type: 'practice',\n229\t        order: 1,\n230\t        status: 'published',\n231\t        isActive: true,\n232\t        tenant: tenantId,\n233\t        locale: 'he',\n234\t        accessType: 'inherit',\n235\t        contentStatus: 'none',\n236\t        contentStatusVisible: true,\n237\t      },\n238\t      draft: false,\n239\t    })\n240\t    sourceLessonId = lesson.id\n241\t    cleanupLessonIds.push(sourceLessonId)\n242\t\n243\t    // Create exactly 5 exercises on the source lesson\n244\t    for (let i = 0; i < 5; i++) {\n245\t      const ex = await payload.create({\n246\t        collection: 'exercises',\n247\t        data: { title: `Orch Exercise ${i} ${ts}`, lesson: sourceLessonId },\n248\t        draft: true,\n249\t      })\n250\t      cleanupExerciseIds.push(ex.id)\n251\t    }\n252\t  }, 120000)\n253\t\n254\t  afterAll(async () => {\n255\t    for (const id of cleanupDuplicationIds) {\n256\t      try {\n257\t        await payload.delete({ collection: 'lesson-duplications', id, overrideAccess: true })\n258\t      } catch {\n259\t        /* ignore */\n260\t      }\n261\t    }\n262\t    for (const id of cleanupExerciseIds) {\n263\t      try {\n264\t        await payload.delete({ collection: 'exercises', id, overrideAccess: true })\n265\t      } catch {\n266\t        /* ignore */\n267\t      }\n268\t    }\n269\t    for (const id of cleanupLessonIds) {\n270\t      try {\n271\t        await payload.delete({ collection: 'lessons', id, overrideAccess: true })\n272\t      } catch {\n273\t        /* ignore */\n274\t      }\n275\t    }\n276\t    try {\n277\t      await payload.delete({ collection: 'chapters', id: chapterId, overrideAccess: true })\n278\t    } catch {\n279\t      /* ignore */\n280\t    }\n281\t    try {\n282\t      await payload.delete({ collection: 'courses', id: courseId, overrideAccess: true })\n283\t    } catch {\n284\t      /* ignore */\n285\t    }\n286\t    try {\n287\t      await payload.delete({ collection: 'categories', id: categoryId, overrideAccess: true })\n288\t    } catch {\n289\t      /* ignore */\n290\t    }\n291\t    await payload.db?.destroy?.()\n292\t  })\n293\t\n294\t  /**\n295\t   * Poll the duplication record until status is no longer 'running' or 'pending'.\n296\t   * Returns the final record state.\n297\t   */\n298\t  async function pollUntilDone(recordId: string): Promise<{\n299\t    status: string\n300\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n301\t    failures: any[]\n302\t\n303\t    outputLesson?: string | null\n304\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n305\t    outputExercises?: any[]\n306\t  }> {\n307\t    let record = await payload.findByID({\n308\t      collection: 'lesson-duplications',\n309\t      id: recordId,\n310\t      depth: 0,\n311\t      overrideAccess: true,\n312\t    })\n313\t    const deadline = Date.now() + 30000\n314\t    while ((record.status === 'running' || record.status === 'pending') && Date.now() < deadline) {\n315\t      await new Promise((r) => setTimeout(r, 500))\n316\t      record = await payload.findByID({\n317\t        collection: 'lesson-duplications',\n318\t        id: recordId,\n319\t        depth: 0,\n320\t        overrideAccess: true,\n321\t      })\n322\t    }\n323\t    // eslint-disable-next-line @typescript-eslint/no-explicit-any\n324\t    return record as any\n325\t  }\n326\t\n327\t  it('5-exercise lesson with one forced failure ends in needs_review with failures recorded', async () => {\n328\t    // Create pending duplication record\n329\t    const record = await payload.create({\n330\t      collection: 'lesson-duplications',\n331\t      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n332\t      overrideAccess: true,\n333\t    })\n334\t    cleanupDuplicationIds.push(record.id)\n335\t\n336\t    expect(record.status).toBe('pending')\n337\t\n338\t    // Run orchestrator (mocked runStrategy forces failure on exercise containing '-3')\n339\t    try {\n340\t      await runDuplicationOrchestrator(record.id, payload)\n341\t    } catch {\n342\t      // Orchestrator may throw if the mock is not properly applied;\n343\t      // we still verify the DB record state below\n344\t    }\n345\t\n346\t    // Poll until done\n347\t    const finalRecord = await pollUntilDone(record.id)\n348\t\n349\t    // Final status must be needs_review (not succeeded, not failed)\n350\t    expect(finalRecord.status).toBe('needs_review')\n351\t\n352\t    // At least one failure entry expected (exercise containing '-3' threw in runStrategy)\n353\t    // Note: the exact count depends on exercise ID strings; we check ≥1 to be robust\n354\t    expect(finalRecord.failures).toBeDefined()\n355\t    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n356\t    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n357\t    expect(finalRecord.failures[0].suggestedAction).toBe('skip')\n358\t\n359\t    // After orchestrator runs, outputLesson should be created\n360\t    // Note: outputExercises remain empty in this test because the runStrategy mock\n361\t    // bypasses processExercise (which calls createOutputExercise). Exercise creation\n362\t    // is verified in lesson-duplication-review-resolve.int.spec.ts instead.\n363\t    expect(finalRecord.outputLesson).toBeTruthy()\n364\t  }, 180000)\n365\t\n366\t  it('orchestrator does not abort when one exercise fails — remaining exercises are processed', async () => {\n367\t    // Create fresh pending record\n368\t    const record = await payload.create({\n369\t      collection: 'lesson-duplications',\n370\t      data: { sourceLesson: sourceLessonId, level: 'medium', status: 'pending' },\n371\t      overrideAccess: true,\n372\t    })\n373\t    cleanupDuplicationIds.push(record.id)\n374\t\n375\t    // Run orchestrator; it may throw if the mock isn't applied (that's ok for this test)\n376\t    try {\n377\t      await runDuplicationOrchestrator(record.id, payload)\n378\t    } catch {\n379\t      // ignore\n380\t    }\n381\t\n382\t    const finalRecord = await pollUntilDone(record.id)\n383\t\n384\t    // The orchestrator should reach needs_review (not 'failed'), meaning it processed\n385\t    // exercises and collected failures rather than crashing completely.\n386\t    // If the orchestrator crashed early, status would be 'failed' with 0 failures.\n387\t    expect(finalRecord.status).toBe('needs_review')\n388\t\n389\t    // At least one failure means at least one exercise failed and the orchestrator\n390\t    // continued processing other exercises (did not abort on first failure).\n391\t    expect(finalRecord.failures).toBeDefined()\n392\t    expect(finalRecord.failures.length).toBeGreaterThanOrEqual(1)\n393\t    expect(finalRecord.failures[0].code).toBe('GENERATION_FAILED')\n394\t\n395\t    // outputLesson should be created even when some exercises fail\n396\t    expect(finalRecord.outputLesson).toBeTruthy()\n397\t  }, 180000)\n398\t})\n399\t"}]},"parent_tool_use_id":null,"session_id":"c813aa32-73d8-4dcb-a1fe-1130176783f8","uuid":"a3a79fb0-65b7-415a-947e-e437bcead6df","timestamp":"2026-05-14T10:31:20.637Z","tool_use_result":{"type":"text","file":{"filePath":"/home/runner/work/A-Guy/A-Guy/tests/int/lesson-duplication-orchestrator.int.spec.ts","content":"/**\n * Integration test: lesson duplication orchestrator.\n *\n * Acceptance criteria:\n *  1. Orchestrator runs at most 4 strategy calls in parallel\n *  2. One exercise failing does not abort the run — remaining exercises complete\n *  3. Failures appear in the DB record as the run progresses (live streaming, asserted by polling)\n *  4. Final status is succeeded only when failures array is empty, else needs_review\n *  5. 5-exercise lesson with one forced failure → needs_review with 4 succeeded + 1 failure entry\n */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest'\nimport { getPayload, type Payload } from 'payload'\nimport config from '@payload-config'\n\nimport { getDefaultTenantSlug } from '@/server/repos/tenant/get-default-tenant'\nimport { runDuplicationOrchestrator } from '@/server/services/lesson-duplication/orchestrator'\n\n<<<<<<< HEAD\n// Mock the LLM variation service to inject failures deterministically.\n// This bypasses the complex runStrategy mock and directly controls LLM call outcomes.\nconst { mockState } = vi.hoisted(() => {\n  let callCount = 0\n  return {\n    mockState: {\n      reset() {\n        callCount = 0\n      },\n      get next() {\n        callCount++\n        return callCount\n      },\n    },\n  }\n})\n=======\n// Mock the variation service so AiVariationStrategy (used for medium/deep level)\n// does not make real LLM calls in the integration test environment.\n// The variation service is only called when level != 'none' &&\n// (level != 'light' || scriptStrategy.needsAiFallback).\n// Uses call-count tracking instead of ID pattern — Payload generates UUIDs for\n// exercise IDs which don't contain '-3', so the old ID-based condition never triggered.\nlet _vgCallCount = 0\nvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n  generateVariation: vi\n    .fn()\n    .mockImplementation(\n      async (\n        input: { exercise: { id: string } },\n        _payload: unknown,\n      ): Promise<{ exercise: { id: string; content: { blocks: unknown[] } } }> => {\n        _vgCallCount++\n        // Force failure on the 3rd exercise (call count 3 = index 2)\n        if (_vgCallCount === 3) {\n          throw new Error('Forced failure for test')\n        }\n        return {\n          exercise: {\n            id: input.exercise.id,\n            content: {\n              blocks: [\n                {\n                  id: 'q-1',\n                  type: 'question_select',\n                  variant: 'mcq',\n                  selectionMode: 'single',\n                  prompt: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'What is 2+2?',\n                    mediaIds: [],\n                  },\n                  answer: {\n                    multiSelect: false,\n                    options: [\n                      {\n                        id: 'a',\n                        content: {\n                          type: 'rich_text',\n                          format: 'md-math-v1',\n                          value: '3',\n                          mediaIds: [],\n                        },\n                      },\n                      {\n                        id: 'b',\n                        content: {\n                          type: 'rich_text',\n                          format: 'md-math-v1',\n                          value: '4',\n                          mediaIds: [],\n                        },\n                      },\n                    ],\n                    correctOptionIds: ['b'],\n                  },\n                  hint: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'Think arithmetic',\n                    mediaIds: [],\n                  },\n                  solution: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: '2+2=4',\n                    mediaIds: [],\n                  },\n                  fullSolution: {\n                    type: 'rich_text',\n                    format: 'md-math-v1',\n                    value: 'Basic addition',\n                    mediaIds: [],\n                  },\n                },\n              ],\n            },\n          },\n        }\n      },\n    ),\n}))\n>>>>>>> origin/dev\n\n// Mock the variation service — throws on the 3rd exercise call to simulate LLM failure\nvi.mock('@/infra/llm/services/lesson-duplication-variation-service', () => ({\n  generateVariation: vi.fn().mockImplementation(async () => {\n    const n = mockState.next\n    if (n === 3) {\n      throw new Error('Forced LLM failure for test')\n    }\n    return {\n      exercise: {\n        id: `mock-exercise-${n}`,\n        content: { blocks: [] },\n      },\n    }\n  }),\n}))\n\nasync function ensureDefaultTenant(payload: Payload): Promise<string> {\n  const slug = getDefaultTenantSlug()\n  const existing = await payload.find({\n    collection: 'tenants',\n    where: { slug: { equals: slug } },\n    limit: 1,\n    overrideAccess: true,\n  })\n  if (existing.docs[0]) return existing.docs[0].id\n  const created = await payload.create({\n    collection: 'tenants',\n    data: { name: slug, slug, status: 'active' },\n    overrideAccess: true,\n  })\n  return created.id\n}\n\n// Reset mock call count before each test to ensure the 3rd exercise always fails\nbeforeEach(() => {\n  mockState.reset()\n})\n\ndescribe('Lesson duplication orchestrator — integration', () => {\n  let payload: Payload\n  let categoryId: string\n  let courseId: string\n  let chapterId: string\n  let tenantId: string\n  let sourceLessonId: string\n  const cleanupLessonIds: string[] = []\n  const cleanupExerciseIds: string[] = []\n  const cleanupDuplicationIds: string[] = []\n\n  beforeEach(() => {\n    _vgCallCount = 0\n  })\n\n  beforeAll(async () => {\n    payload = await getPayload({ config })\n    tenantId = await ensureDefaultTenant(payload)\n    const ts = Date.now()\n\n    const category = await payload.create({\n      collection: 'categories',\n      data: { title: `OrchCat ${ts}`, slug: `orch-cat-${ts}`, locale: 'he' },\n    })\n    categoryId = category.