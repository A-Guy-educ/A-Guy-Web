{
  "behaviors": [
    {
      "id": "login-loading",
      "feature": "auth",
      "type": "loading",
      "loadingType": "spinner",
      "duration": 1500,
      "transition": {
        "type": "fade",
        "duration": 200
      },
      "description": "Show spinner in button during login API call"
    },
    {
      "id": "login-error-inline",
      "feature": "auth",
      "type": "error",
      "errorType": "validation",
      "display": "inline",
      "recoverable": true,
      "retryable": false,
      "userInputPreserved": true,
      "message": "שם משתמש או סיסמה שגויים",
      "description": "Show inline error message below form"
    },
    {
      "id": "login-redirect-success",
      "feature": "auth",
      "type": "animation",
      "animationType": "fade",
      "duration": 300,
      "trigger": "immediate",
      "description": "Redirect to dashboard on successful login"
    },
    {
      "id": "session-timeout",
      "feature": "auth",
      "type": "auth",
      "flow": "session-timeout",
      "redirectTo": "/login",
      "preserveState": true,
      "description": "Session expires after 30 minutes of inactivity"
    }
  ]
}
