#!/bin/sh

# Allow skipping hooks with SKIP_HOOKS=1
. "$(dirname "$0")/skip-hooks.sh"

# Allow commits with [skip ci] flag (used by CI/CD systems like semantic-release)
# This is needed for automated releases to commit changelog updates
if [ "$SKIP_HOOKS" = "1" ]; then
  exit 0
fi

# Get current branch name
branch=$(git rev-parse --abbrev-ref HEAD)

# Prevent direct commits to protected branches (main) unless CI-initiated
if [ "$branch" = "main" ]; then
  # Check if this is a CI-initiated commit:
  # 1. Running in GitHub Actions (GITHUB_ACTIONS is set)
  # 2. Has SKIP_HOOKS=1 set
  if [ -n "$GITHUB_ACTIONS" ] || [ "$SKIP_HOOKS" = "1" ]; then
    echo ""
    echo "ℹ️  CI-initiated commit to '$branch' detected. Skipping branch protection check."
    echo ""
    exit 0
  fi

  echo ""
  echo "❌ ERROR: Direct commits to '$branch' branch are not allowed"
  echo ""
  echo "All changes must go through pull requests. Please create a feature branch:"
  echo ""
  echo "  git checkout -b feat/<description>"
  echo "  git checkout -b fix/<description>"
  echo "  git checkout -b chore/<description>"
  echo ""
  echo "Examples:"
  echo "  git checkout -b feat/user-authentication"
  echo "  git checkout -b fix/login-bug"
  echo "  git checkout -b chore/update-dependencies"
  echo ""
  echo "Then commit your changes and create a pull request."
  echo ""
  echo "To skip this check (not recommended):"
  echo "  git commit --no-verify"
  echo "  Or use: SKIP_HOOKS=1 git commit"
  echo ""
  echo "For detailed help, see: docs/specs/COMMIT_GUIDE.md"
  echo ""
  exit 1
fi

# Validate branch naming convention (skip in CI - agents use their own conventions)
# TEMPORARILY DISABLED for dev branch commits
if [ -n "$GITHUB_ACTIONS" ] || [ "$branch" = "dev" ]; then
  echo ""
  echo "ℹ️  CI environment detected. Skipping branch naming convention check."
  echo ""
else
  # Allowed patterns: feat/, fix/, chore/, docs/, refactor/, test/, security/
  if ! echo "$branch" | grep -qE '^(feat|fix|chore|docs|refactor|test|security)/[a-z0-9-]+$'; then
    echo ""
    echo "❌ ERROR: Invalid branch name: '$branch'"
    echo ""
    echo "Branch names must follow one of these patterns:"
    echo "  ✅ feat/<description>     - New features"
    echo "  ✅ fix/<description>      - Bug fixes"
    echo "  ✅ chore/<description>    - Maintenance tasks"
    echo "  ✅ docs/<description>     - Documentation changes"
    echo "  ✅ refactor/<description> - Code refactoring"
    echo "  ✅ test/<description>     - Test additions/changes"
    echo "  ✅ security/<description> - Security fixes"
    echo ""
    echo "Examples:"
    echo "  git checkout -b feat/user-authentication"
    echo "  git checkout -b fix/login-bug"
    echo "  git checkout -b chore/update-dependencies"
    echo ""
    echo "To rename your branch:"
    echo "  git branch -m <new-branch-name>"
    echo ""
    echo "To skip this check once:"
    echo "  git commit --no-verify"
    echo ""
    echo "For detailed help, see: docs/specs/COMMIT_GUIDE.md"
    echo ""
    exit 1
  fi
fi

# Run checks in parallel for faster execution
{
  .husky/check-secrets &
  PID1=$!

  .husky/check-no-css &
  PID2=$!

  .husky/check-archivedAt-invariant &
  PID3=$!

  # Wait for all to complete
  wait $PID1 $PID2 $PID3
}

# If any check failed, exit
if [ $? -ne 0 ]; then
  exit 1
fi

# Run lint-staged (auto-fixes formatting + linting)
echo ""
echo "🎨 Running lint-staged (auto-formatting & linting)..."
pnpm exec lint-staged

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Linting failed. Please fix the errors and try again."
  exit 1
fi

echo "✅ Lint-staged passed"

# Fast type checking on staged TypeScript files only
echo ""
echo "🔍 Type checking staged files..."
pnpm exec tsc --noEmit --incremental false

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Type checking failed. Please fix type errors and try again."
  echo ""
  echo "To see all errors: pnpm typecheck"
  echo "To skip: git commit --no-verify"
  exit 1
fi

echo "✅ Type checking passed"
echo ""
echo "✅ Pre-commit checks passed!"
echo "⚠️  Full build & tests will run in CI"
