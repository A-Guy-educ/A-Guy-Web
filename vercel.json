{
  "git": {
    "deploymentEnabled": {
      "kody-state": false
    }
  },
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ':(exclude).kody/**' ':(exclude)CHANGELOG.md'",
  "crons": [
    {
      "path": "/api/cron/warmup",
      "schedule": "*/4 * * * *"
    },
    {
      "path": "/api/cron/process-duplications",
      "schedule": "* * * * *"
    }
  ]
}
