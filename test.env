NODE_OPTIONS="--no-deprecation"

# Payload CMS secret (required for E2E tests)
PAYLOAD_SECRET=test-secret-key-for-e2e-tests-only

# Feature flags for memory system tests
SUMMARY_MAINTENANCE_ENABLED=true
MEMORY_EXTRACTION_ENABLED=true
MEMORY_RETRIEVAL_ENABLED=true

# OpenAI API (mocked by default in tests, set USE_REAL_OPENAI_API=true to test with real API)
OPENAI_API_KEY=sk-mock-key-for-testing
