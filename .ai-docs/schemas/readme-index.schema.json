{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "README Index",
  "type": "object",
  "required": ["readmes", "metadata"],
  "properties": {
    "readmes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "title", "sections", "relativeUrl", "category", "wordCount"],
        "properties": {
          "path": { "type": "string" },
          "title": { "type": "string" },
          "sections": { "type": "array", "items": { "type": "string" } },
          "relativeUrl": { "type": "string" },
          "category": { "type": "string" },
          "wordCount": { "type": "number" }
        },
        "additionalProperties": true
      }
    },
    "metadata": {
      "type": "object",
      "required": ["generatedAt", "totalReadmes", "categories"],
      "properties": {
        "generatedAt": { "type": "string" },
        "totalReadmes": { "type": "number" },
        "categories": { "type": "object", "additionalProperties": { "type": "number" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
