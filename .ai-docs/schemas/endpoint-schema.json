{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aguy.com/schemas/api-endpoint.json",
  "title": "API Endpoint Contract",
  "description": "Schema for validating API endpoint patterns in the A-Guy platform",
  "type": "object",
  "required": ["method", "path", "authentication", "validation"],
  "properties": {
    "method": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
      "description": "HTTP method for the endpoint"
    },
    "path": {
      "type": "string",
      "pattern": "^/",
      "description": "Endpoint path (must start with /)",
      "examples": ["/api/courses", "/api/exercises/:id", "/api/users/profile"]
    },
    "authentication": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": {
          "type": "boolean",
          "description": "Whether authentication is required"
        },
        "method": {
          "type": "string",
          "enum": ["payload-auth", "jwt", "api-key"],
          "description": "Authentication method used",
          "default": "payload-auth"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["admin", "instructor", "student", "user"]
          },
          "description": "Required user roles (if auth is required)"
        }
      }
    },
    "authorization": {
      "type": "object",
      "description": "Authorization checks beyond authentication",
      "properties": {
        "required": {
          "type": "boolean",
          "description": "Whether resource-level authorization is required"
        },
        "type": {
          "type": "string",
          "enum": ["owner", "role-based", "custom"],
          "description": "Type of authorization check"
        },
        "description": {
          "type": "string",
          "description": "Description of authorization logic"
        }
      }
    },
    "validation": {
      "type": "object",
      "required": ["library", "schema"],
      "properties": {
        "library": {
          "type": "string",
          "enum": ["zod"],
          "description": "Validation library (must use Zod)"
        },
        "schema": {
          "type": "string",
          "description": "Name of the validation schema",
          "pattern": "^[a-zA-Z][a-zA-Z0-9]*Schema$",
          "examples": ["createCourseSchema", "updateUserSchema", "exerciseAnswerSchema"]
        },
        "validateParams": {
          "type": "boolean",
          "description": "Whether to validate URL parameters"
        },
        "validateQuery": {
          "type": "boolean",
          "description": "Whether to validate query string parameters"
        },
        "validateBody": {
          "type": "boolean",
          "description": "Whether to validate request body"
        }
      }
    },
    "errorHandling": {
      "type": "object",
      "description": "Error handling configuration",
      "properties": {
        "hasTryCatch": {
          "type": "boolean",
          "description": "Whether endpoint has try/catch block",
          "default": true
        },
        "logging": {
          "type": "boolean",
          "description": "Whether errors are logged with Pino",
          "default": true
        },
        "statusCodes": {
          "type": "array",
          "items": {
            "type": "integer",
            "enum": [200, 201, 400, 401, 403, 404, 500]
          },
          "description": "HTTP status codes used by endpoint",
          "examples": [[200, 400, 401, 500]]
        }
      }
    },
    "rateLimit": {
      "type": "object",
      "description": "Rate limiting configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether rate limiting is applied"
        },
        "requestsPerMinute": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum requests per minute"
        }
      }
    },
    "response": {
      "type": "object",
      "description": "Response format",
      "properties": {
        "format": {
          "type": "string",
          "enum": ["json", "text", "stream"],
          "default": "json",
          "description": "Response format"
        },
        "schema": {
          "type": "string",
          "description": "Response schema name (for documentation)"
        }
      }
    },
    "payloadIntegration": {
      "type": "object",
      "description": "Payload CMS integration",
      "properties": {
        "usesPayload": {
          "type": "boolean",
          "description": "Whether endpoint uses Payload CMS"
        },
        "collections": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Payload collections accessed by endpoint"
        },
        "operations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["find", "findByID", "create", "update", "delete"]
          },
          "description": "Payload operations used"
        }
      }
    }
  },
  "examples": [
    {
      "method": "POST",
      "path": "/api/courses",
      "authentication": {
        "required": true,
        "method": "payload-auth",
        "roles": ["admin", "instructor"]
      },
      "authorization": {
        "required": false
      },
      "validation": {
        "library": "zod",
        "schema": "createCourseSchema",
        "validateBody": true
      },
      "errorHandling": {
        "hasTryCatch": true,
        "logging": true,
        "statusCodes": [201, 400, 401, 403, 500]
      },
      "response": {
        "format": "json",
        "schema": "CourseResponse"
      },
      "payloadIntegration": {
        "usesPayload": true,
        "collections": ["courses"],
        "operations": ["create"]
      }
    },
    {
      "method": "GET",
      "path": "/api/exercises/:id",
      "authentication": {
        "required": false
      },
      "authorization": {
        "required": false
      },
      "validation": {
        "library": "zod",
        "schema": "exerciseParamsSchema",
        "validateParams": true
      },
      "errorHandling": {
        "hasTryCatch": true,
        "logging": true,
        "statusCodes": [200, 404, 500]
      },
      "response": {
        "format": "json",
        "schema": "ExerciseResponse"
      },
      "payloadIntegration": {
        "usesPayload": true,
        "collections": ["exercises"],
        "operations": ["findByID"]
      }
    },
    {
      "method": "PUT",
      "path": "/api/users/profile",
      "authentication": {
        "required": true,
        "method": "payload-auth"
      },
      "authorization": {
        "required": true,
        "type": "owner",
        "description": "User can only update their own profile"
      },
      "validation": {
        "library": "zod",
        "schema": "updateProfileSchema",
        "validateBody": true
      },
      "errorHandling": {
        "hasTryCatch": true,
        "logging": true,
        "statusCodes": [200, 400, 401, 403, 500]
      },
      "rateLimit": {
        "enabled": true,
        "requestsPerMinute": 10
      },
      "response": {
        "format": "json",
        "schema": "UserResponse"
      },
      "payloadIntegration": {
        "usesPayload": true,
        "collections": ["users"],
        "operations": ["update"]
      }
    }
  ],
  "definitions": {
    "patterns": {
      "publicEndpoint": {
        "description": "Public endpoint with no authentication",
        "requirements": [
          "Set authentication.required to false",
          "Still validate input with Zod",
          "Apply rate limiting",
          "Log all requests"
        ]
      },
      "authenticatedEndpoint": {
        "description": "Endpoint requiring user authentication",
        "requirements": [
          "Use Payload auth: await payload.auth({ headers: req.headers })",
          "Check if user exists",
          "Return 401 if not authenticated",
          "Pass user to Payload operations"
        ]
      },
      "adminOnlyEndpoint": {
        "description": "Endpoint restricted to admin users",
        "requirements": [
          "Check authentication first",
          "Verify user.roles.includes('admin')",
          "Return 403 if not admin",
          "Log admin actions"
        ]
      },
      "resourceOwnerEndpoint": {
        "description": "Endpoint where user can only access their own resources",
        "requirements": [
          "Check authentication first",
          "Verify resource belongs to user",
          "Return 403 if not owner (or 404 to prevent enumeration)",
          "Allow admin override"
        ]
      }
    }
  },
  "notes": [
    "CRITICAL: ALWAYS validate input with Zod schemas - never trust client data",
    "CRITICAL: ALWAYS use try/catch for error handling",
    "CRITICAL: ALWAYS log errors with appropriate context",
    "SECURITY: Check authentication BEFORE any operations",
    "SECURITY: Check authorization AFTER authentication",
    "SECURITY: Return 401 for authentication failures, 403 for authorization failures",
    "SECURITY: Use 404 instead of 403 when you don't want to leak resource existence",
    "BEST PRACTICE: Use Payload auth for user authentication: payload.auth({ headers })",
    "BEST PRACTICE: Pass user to Payload operations to enforce access control",
    "BEST PRACTICE: Return consistent error format: { error: string, details?: any }",
    "BEST PRACTICE: Return success format: { success: boolean, data: T }",
    "PATTERN: For mutations (POST, PUT, PATCH, DELETE), validate body with Zod",
    "PATTERN: For GET with params, validate params with Zod",
    "PATTERN: For query strings, validate with Zod and provide defaults",
    "TESTING: Create integration tests for all endpoints",
    "TESTING: Test authentication and authorization failures",
    "TESTING: Test input validation edge cases"
  ]
}
