#!/bin/sh
# Block CSS/SCSS files from being committed
# This project uses Tailwind CSS only - no CSS/SCSS files allowed
# Exception: src/app/(frontend)/globals.css is allowed (design system file)

staged_css=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(css|scss|sass)$' | grep -v 'src/app/(frontend)/globals.css' || true)

if [ -n "$staged_css" ]; then
  echo "❌ ERROR: CSS/SCSS files are not allowed in this project"
  echo "This project uses Tailwind CSS exclusively."
  echo ""
  echo "Blocked files:"
  echo "$staged_css" | sed 's/^/  - /'
  echo ""
  echo "Please remove these files and use Tailwind utility classes instead."
  echo "See AGENTS.md for styling guidelines."
  echo ""
  echo "Exception: src/app/(frontend)/globals.css is allowed for design system variables."
  echo ""
  echo "For detailed help, see: docs/specs/COMMIT_GUIDE.md"
  exit 1
fi
