{
  "name": "a-guy",
  "version": "0.14.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS='--no-deprecation --max-old-space-size=4096' next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "build:analyze": "cross-env ANALYZE=true pnpm build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:fast": "cross-env NEXT_TURBOPACK_DEV=0 NODE_OPTIONS=--no-deprecation next dev",
    "dev:clean": "rm -rf .next && pnpm dev",
    "dev:test": "cross-env NODE_ENV=test pnpm dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env PAYLOAD_GENERATE_TYPES=true NODE_OPTIONS=--no-deprecation payload generate:types",
    "ai:generate-docs": "pnpm tsx scripts/generate-doc-chunks.ts",
    "ai:generate-patterns": "pnpm tsx scripts/generate-pattern-index.ts",
    "ai:generate-readme-index": "pnpm tsx scripts/generate-readme-index.ts",
    "ai:generate-all": "pnpm run ai:generate-docs && pnpm run ai:generate-patterns && pnpm run ai:generate-readme-index",
    "ai:test-search": "pnpm tsx scripts/test-doc-search.ts",
    "ai:test-loader": "pnpm tsx scripts/test-smart-loader.ts",
    "ai:generate-route-index": "pnpm tsx scripts/generate-route-index.ts",
    "ai:generate-collection-slug-map": "pnpm tsx scripts/generate-collection-slug-map.ts",
    "ai:generate-all-indexes": "pnpm run ai:generate-readme-index && pnpm run ai:generate-route-index && pnpm run ai:generate-collection-slug-map",
    "ai:validate-indexes": "pnpm tsx scripts/validate-indexes.ts",
    "docs:links:fix": "pnpm tsx scripts/doc-link-fixer.ts",
    "nightly-docs": "pnpm tsx scripts/nightly-docs/index.ts",
    "deps:security:report": "pnpm tsx scripts/deps-security-report.ts",
    "repo:hygiene:report": "pnpm tsx scripts/repo-hygiene-report.ts",
    "mcp:discover-tools": "pnpm tsx scripts/admin-chat-mcp_discover-tools.ts",
    "validate:readme-links": "pnpm tsx scripts/validate-readme-links.ts",
    "validate:env": "pnpm tsx scripts/validate-env.ts",
    "check:branch": "pnpm tsx scripts/check-branch.ts",
    "check:release": "pnpm tsx scripts/pre-release-check.ts",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:all": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,yml,yaml}\"",
    "fix": "pnpm lint:fix && pnpm format",
    "fix:all": "pnpm typecheck && pnpm lint:fix && pnpm format && pnpm test",
    "fix:changed": "node scripts/fix-changed.mjs",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "worker": "cross-env NODE_OPTIONS=--no-deprecation payload jobs:run",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:unit && pnpm run test:int && pnpm run test:e2e",
    "test:unit": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.unit.mts",
    "test:unit:watch": "cross-env NODE_OPTIONS=--no-deprecation vitest watch --config ./vitest.config.unit.mts",
    "test:unit:coverage": "cross-env NODE_OPTIONS=--no-deprecation vitest run --coverage --config ./vitest.config.unit.mts",
    "test:e2e": "pnpm exec playwright test --config=playwright.config.ts",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:e2e:debug": "pnpm exec playwright test --debug",
    "test:e2e:headed": "pnpm exec playwright test --headed",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:int:cody": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.cody-int.mts",
    "test:int:atlas": "cross-env USE_ATLAS=true NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:vector": "cross-env USE_ATLAS=true NODE_OPTIONS=--no-deprecation vitest run tests/int/vector-*.int.spec.ts --config ./vitest.config.mts",
    "test:watch": "vitest watch --config ./vitest.config.mts",
    "test:ui": "vitest --ui --config ./vitest.config.mts",
    "test:coverage": "vitest run --coverage --config ./vitest.config.mts",
    "typecheck": "tsc --noEmit",
    "setup": "pnpm tsx scripts/setup.ts",
    "doctor": "pnpm tsx scripts/doctor.ts",
    "migrate:tenant": "pnpm tsx src/server/payload/migrations/001-backfill-tenant.ts",
    "migration:migrate-media": "pnpm tsx src/server/payload/migrations/migrate-media-to-blob.ts",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "verify:vector-index": "pnpm tsx scripts/verify-vector-index.ts",
    "db:restart": "docker-compose restart",
    "db:reset": "docker-compose down -v && docker-compose up -d",
    "db:logs": "docker-compose logs -f mongo",
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo",
    "clean:all": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo node_modules pnpm-lock.yaml",
    "deps:check": "pnpm outdated",
    "deps:update": "pnpm update --latest --interactive",
    "deps:audit": "pnpm audit --audit-level=moderate",
    "ci:local": "pnpm typecheck && pnpm lint && pnpm test",
    "ci:quality": "pnpm typecheck && pnpm lint && pnpm format:check",
    "ci:test": "pnpm test:int && pnpm test:e2e",
    "maintenance": "pnpm clean && pnpm deps:update && pnpm install && pnpm ci:local",
    "precommit": "lint-staged",
    "release": "semantic run generate:types-release",
    "release:dry-run": "semantic-release --dry-run",
    "prepare": "husky && chmod +x .husky/pre-commit .husky/commit-msg .husky/pre-push .husky/post-commit .husky/post-merge .husky/check-secrets .husky/check-no-css .husky/check-archivedAt-invariant .husky/skip-hooks.sh",
    "verify": "pnpm tsx scripts/verify.ts",
    "ocode": "opencode",
    "setup:opencode": "curl -fsSL https://opencode.ai/install | bash",
    "cody:spec": "pnpm tsx scripts/cody/cody.ts --mode=spec",
    "cody:impl": "pnpm tsx scripts/cody/cody.ts --mode=impl",
    "cody:rerun": "pnpm tsx scripts/cody/cody.ts --mode=rerun",
    "cody": "pnpm tsx scripts/cody/cody.ts",
    "supervisor": "pnpm tsx scripts/supervisor/supervisor.ts"
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.28.0",
    "@google/generative-ai": "^0.24.1",
    "@marsidev/react-turnstile": "^1.4.1",
    "@napi-rs/canvas": "^0.1.89",
    "@payloadcms/admin-bar": "3.73.0",
    "@payloadcms/db-mongodb": "3.73.0",
    "@payloadcms/live-preview-react": "3.73.0",
    "@payloadcms/next": "3.73.0",
    "@payloadcms/plugin-form-builder": "3.73.0",
    "@payloadcms/plugin-mcp": "^3.73.0",
    "@payloadcms/plugin-nested-docs": "3.73.0",
    "@payloadcms/plugin-redirects": "3.73.0",
    "@payloadcms/plugin-search": "3.73.0",
    "@payloadcms/plugin-seo": "3.73.0",
    "@payloadcms/richtext-lexical": "3.73.0",
    "@payloadcms/storage-vercel-blob": "^3.73.0",
    "@payloadcms/ui": "3.73.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@sentry/nextjs": "^10.32.1",
    "@vercel/blob": "^0.22.3",
    "ajv": "^8.17.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "17.2.3",
    "geist": "^1.3.0",
    "genkit": "^1.28.0",
    "genkitx-openai": "^0.30.0",
    "graphql": "^16.8.2",
    "import-in-the-middle": "^3.0.0",
    "jose": "^6.1.3",
    "katex": "^0.16.27",
    "lightningcss": "1.30.2",
    "lucide-react": "^0.562.0",
    "mongodb": "^6.12.0",
    "nanoid": "^5.0.0",
    "next": "15.5.9",
    "next-sitemap": "^4.2.3",
    "openai": "^4.77.3",
    "payload": "3.73.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.168",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "7.70.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "require-in-the-middle": "^8.0.1",
    "slugify": "^1.6.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.57.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.13",
    "@testcontainers/mongodb": "^11.11.0",
    "@testing-library/react": "16.3.1",
    "@types/escape-html": "^1.0.2",
    "@types/hast": "^3.0.4",
    "@types/node": "^22.5.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.19",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.7",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "^16.2.7",
    "opencode-ai": "^1.2.10",
    "playwright": "1.57.0",
    "playwright-core": "1.57.0",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "semantic-release": "^25.0.2",
    "semantic-release-slack-bot": "^4.0.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "testcontainers": "^11.11.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "4.0.16",
    "yaml": "^2.8.2"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0 || ^22.14.0 || >=24.10.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "cpu-features",
      "protobufjs",
      "sharp",
      "ssh2",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "@modelcontextprotocol/sdk": ">=1.25.2"
    }
  }
}
