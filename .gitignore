build
dist / media
node_modules
.DS_Store
.env
.env.*
!.env.example
!.env.test.example
!.env.docker.example
.next
.vercel
.pnpm-store

# Payload default media upload directory
public/media/

# Local-only testing materials for interactive lesson / schema work
schema-testing/

public/robots.txt
public/sitemap*.xml


# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/


tsconfig.tsbuildinfo

# Payload generated artifacts — regenerated on install/dev/build from payload.config.ts
src/payload-types.ts
src/app/(payload)/admin/importMap.js

# Local AI development documentation
CLAUDE_INTERNAL.md
NAMING.md
STRICTNESS.md

# Test coverage reports
coverage/
*.lcov

# Auditor run bundles (ephemeral, only auditor.json is durable)
*/runs/*/bundle.json

# Browser Agent
scripts/browser-agent/.auth/
scripts/browser-agent/.env
.opencode-auth.json
.gh-hosts.yml

# GSD planning state (ephemeral, regenerated per run)
.planning/

# OpenCode runtime files (per-task isolated data dirs)
# Only opencode.db is committed for session continuation across reruns
*/opencode-data/opencode/opencode.db-wal
*/opencode-data/opencode/opencode.db-shm
*/opencode-data/opencode/snapshot/
*/opencode-data/opencode/logs/
*/opencode-data/opencode/auth.json
*/opencode-data/opencode/bin/
*/opencode-data/opencode/tool-output/
*/opencode-data/opencode/storage/
*/opencode-data/opencode/worktree/
.env*.local

# Task specs (local only)
shay-tassk/

# LaTeX example files (local only)
latex_examples/

# kody graph transient artifacts (do not commit)
.kody/graph/.graph-lock
.kody/graph/.graph-lock.lock/
.kody/graph/*.bak
.kody/graph/*.tmp.*
.kody/graph/episodes/*.bak
.kody/graph/episodes/*.tmp.*

# kody mission state — durable across runs via the local-file backend's
# Actions cache snapshot (see kody.config.json missions.stateBackend).
# Tracked-file commits would re-introduce the churn this design eliminates.
.kody/missions/*.state.json

# kody job state — same rationale as missions, see kody.config.json jobs.stateBackend.
.kody/jobs/*.state.json

# kody qa-engineer artifacts — ad-hoc screenshots, snapshots, console logs.
# The Playwright MCP server writes its own working dir at the repo root.
.kody/qa-reports/
.playwright-mcp/
