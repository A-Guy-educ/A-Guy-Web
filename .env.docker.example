# =============================================================================
# A-Guy Development Container Environment Variables
# =============================================================================
# Purpose: Template for Docker dev environment - copy to .env.docker
# 
# Instructions:
#   1. Copy this file: cp .env.docker.example .env.docker
#   2. Fill in your actual values
#   3. NEVER commit .env.docker to version control
# =============================================================================

# =============================================================================
# Required Variables
# =============================================================================

# Database connection (use 'mongo' for container networking, 'localhost' for host)
# Inside container use hostname "mongo" (resolves via docker network)
DATABASE_URL=mongodb://mongo:27017/a-guy-dev
# From host machine use port 27018 to avoid conflict with docker-compose.yml
# DATABASE_URL=mongodb://localhost:27018/a-guy-dev

# Payload JWT secret (generate: openssl rand -base64 32)
PAYLOAD_SECRET=your-secret-here-change-me

# Server URL
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# =============================================================================
# Optional: LLM Providers (at least one needed for AI features)
# =============================================================================

# Google Gemini API (recommended)
# Get key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI (alternative)
# OPENAI_API_KEY=your-openai-api-key-here

# OpenAI-compatible (Ollama, LM Studio, etc.)
# OPENAI_COMPATIBLE_API_KEY=your-api-key-here
# OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:11434/v1

# =============================================================================
# Optional: GitHub Integration
# =============================================================================

# GitHub Token (for Cody pipeline, API access)
# GITHUB_TOKEN=your-github-token-here
# GITHUB_OWNER=your-github-org
# GITHUB_REPO=your-repo-name

# =============================================================================
# Optional: Authentication
# =============================================================================

# Google OAuth (if using Google login)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# =============================================================================
# Optional: Storage
# =============================================================================

# Vercel Blob (for media storage)
# BLOB_READ_WRITE_TOKEN=vercel_blob_xxxx

# =============================================================================
# Optional: Analytics
# =============================================================================

# Google Analytics (dev uses test ID)
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-49KEEFY1WE

# Mixpanel
# NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# =============================================================================
# Optional: Development Settings
# =============================================================================

# Enable Ollama for local AI (set to 'true' to enable)
# USE_OLLAMA=false

# Logging level
LOG_LEVEL=info

# Enable MCP (Model Context Protocol)
# MCP_ENABLED=false
# MCP_API_KEY=your-mcp-api-key

# =============================================================================
# Advanced: Do Not Modify Unless Needed
# =============================================================================

# MongoDB pool size
# MONGODB_MAX_POOL_SIZE=5

# Node environment
NODE_ENV=development
